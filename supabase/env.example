# Local Supabase (CLI) environment file.
# Copy this file to `supabase/.env` (this path is ignored by git) and fill the values.
#
# You can get SUPABASE_URL / ANON / SERVICE_ROLE from `supabase status`.
#
# Tip: you can start Supabase local while auto-loading `supabase/.env` with:
#   ./scripts/supabase_local.sh start
#
# Recommended:
# - Put WhatsApp secrets in `supabase/.env.local` (see `supabase/env.local.template`).
# - For local dev without real outbound delivery, set `EMAIL_DELIVERY_ENABLED=0` and `WHATSAPP_DELIVERY_ENABLED=0`.

# --- Edge Functions runtime ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=__set_from_supabase_status__
SUPABASE_SERVICE_ROLE_KEY=__set_from_supabase_status__

# LLM
GEMINI_API_KEY=__your_gemini_key__
OPENAI_API_KEY=__your_openai_key__
# Optional: override OpenAI base URL (leave default unless you use a proxy).
OPENAI_BASE_URL=https://api.openai.com
# Optional: default model overrides (if unset, code falls back to sane defaults).
# - GEMINI_SOPHIA_CHAT_MODEL: used for investigator/companion/architect (router-enforced).
# - GEMINI_JUDGE_MODEL: used by eval-judge when request doesn't override the model.
GEMINI_SOPHIA_CHAT_MODEL=gemini-2.5-flash
GEMINI_JUDGE_MODEL=gemini-3-pro-preview
# Optional: fallback model used when the primary model is overloaded (429/503) after several retries.
# Leave empty to disable model fallback.
GEMINI_FALLBACK_MODEL=
# Research overlay (default off): pre-agent web grounding for factual/live queries.
RESEARCH_OVERLAY_ENABLED=0

# Scoped conversation memory compaction
# - Applies to whatsapp and isolated scopes like module:*, story:*, reflection:*.
# - Threshold is in messages, not turns. Recent verbatim window uses max(recent_min, pending_messages).
SOPHIA_SCOPE_MEMORY_THRESHOLD=15
SOPHIA_SCOPE_MEMORY_RECENT_MIN=5
SOPHIA_SCOPE_MEMORY_MODEL=gemini-2.5-flash

# Verifier (prod): semantic anti-loop (assistant repetition guard)
# - compares current assistant message to the last N assistant messages (window) using embeddings cosine similarity.
# - if similarity >= threshold, flags `mech:semantic_repeats_previous_question` and may trigger rewrite.
SOPHIA_VERIFIER_SEMANTIC_REPEAT_WINDOW=5
SOPHIA_VERIFIER_SEMANTIC_REPEAT_THRESHOLD=0.92

# Disable Judge+Rewrite verifiers (latency-heavy) by channel (recommended ON for local web dev).
SOPHIA_VERIFIER_DISABLE_WEB=1
SOPHIA_VERIFIER_DISABLE_WHATSAPP=0

# Internal call auth for service-role Edge Functions (cron + db triggers)
INTERNAL_FUNCTION_SECRET=__set_a_long_random_string__

# Outbound delivery toggles
# - Set to 0/false/off to keep flows running without sending real emails or WhatsApp messages.
EMAIL_DELIVERY_ENABLED=1
WHATSAPP_DELIVERY_ENABLED=1

# Stripe (billing)
# - STRIPE_SECRET_KEY: starts with sk_
# - STRIPE_WEBHOOK_SECRET: starts with whsec_
# - STRIPE_PRICE_ID_*: starts with price_
# - APP_BASE_URL: where Stripe redirects after Checkout/Portal (ex: http://localhost:5173)
STRIPE_SECRET_KEY=__your_stripe_secret_key__
STRIPE_WEBHOOK_SECRET=__your_stripe_webhook_secret__
#
# 3 tiers x 2 intervals (monthly/yearly)
STRIPE_PRICE_ID_SYSTEM_MONTHLY=__your_system_monthly_price_id__
STRIPE_PRICE_ID_SYSTEM_YEARLY=__your_system_yearly_price_id__
STRIPE_PRICE_ID_ALLIANCE_MONTHLY=__your_alliance_monthly_price_id__
STRIPE_PRICE_ID_ALLIANCE_YEARLY=__your_alliance_yearly_price_id__
STRIPE_PRICE_ID_ARCHITECTE_MONTHLY=__your_architecte_monthly_price_id__
STRIPE_PRICE_ID_ARCHITECTE_YEARLY=__your_architecte_yearly_price_id__
APP_BASE_URL=http://localhost:5173

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=__your_whatsapp_cloud_api_access_token__
WHATSAPP_PHONE_NUMBER_ID=__your_phone_number_id__
WHATSAPP_APP_SECRET=__your_meta_app_secret__
WHATSAPP_WEBHOOK_VERIFY_TOKEN=__set_a_random_verify_token__
WHATSAPP_OPTIN_TEMPLATE_NAME=sophia_optin_v1
WHATSAPP_OPTIN_TEMPLATE_LANG=fr
WHATSAPP_BILAN_WINBACK_STEP1_TEMPLATE_NAME=sophia_winback_step1_soft
WHATSAPP_BILAN_WINBACK_STEP2_TEMPLATE_NAME=sophia_winback_step2_refocus
WHATSAPP_BILAN_WINBACK_STEP3_TEMPLATE_NAME=sophia_winback_step3_opendoor
WHATSAPP_BILAN_WINBACK_TEMPLATE_LANG=fr
WHATSAPP_CHECKIN_TEMPLATE_NAME=sophia_checkin_v1
WHATSAPP_CHECKIN_TEMPLATE_LANG=fr
WHATSAPP_WEEKLY_PLANNING_TEMPLATE_NAME=weekly_planning_validation_v1
WHATSAPP_WEEKLY_PLANNING_TEMPLATE_LANG=fr
WHATSAPP_WEEKLY_PROGRESS_REVIEW_TEMPLATE_NAME=sophia_bilan_weekly_v1
WHATSAPP_WEEKLY_PROGRESS_REVIEW_TEMPLATE_LANG=fr

# --- Vault (DB) ---
# Used by Supabase Vault locally to encrypt/decrypt secrets.
SUPABASE_VAULT_SECRET_KEY=__set_a_long_random_string__

# --- Optional (Edge runtime secrets envelope) ---
SUPABASE_EDGE_SECRETS_KEY=__set_a_long_random_string__

# --- Memory V2-only (cf. plan/memory-v2-mvp-consolidated-architecture-plan.md) ---
# Gemini embedding model used for memory_items, user_entities, user_topic_memories.search_doc_embedding.
# Dimension is forced to 768 (cf. geminiEmbed in supabase/functions/_shared/llm.ts).
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# LLM models used by the V2-only memorizer / runtime.
MEMORY_V2_EXTRACTION_MODEL=gemini-3-flash-preview
MEMORY_V2_ROUTER_MODEL=gemini-3-flash-preview
MEMORY_V2_COMPACTION_MODEL=gemini-3-flash-preview
MEMORY_V2_DOMAIN_MAPPER_MODEL=gemini-2.5-flash
# Identifier stored in DB rows (format: <model>@<dim>). Lets us migrate model later without breaking existing rows.
MEMORY_V2_EMBEDDING_MODEL_TAG=gemini-embedding-001@768

# Runtime V2-only controls. Disabling the loader/memorizer never re-enables V1.
memory_v2_loader_disabled=0
memory_v2_loader_timeout_ms=1500
memory_v2_memorizer_disabled=0
memory_v2_memorizer_cost_cap_user_day_eur=0.60

# Topic compaction. Enable after loader/corrections are stable.
memory_v2_topic_compaction_enabled=0

# Weekly memory review. Keep disabled until local/staging checks are green.
memory_v2_weekly_review_enabled=0

# Sprint 12 Memory V2 ops alerts. Webhook is optional; when unset, alerts are returned/logged only.
memory_v2_alerts_enabled=0
MEMORY_V2_ALERT_WEBHOOK_URL=
